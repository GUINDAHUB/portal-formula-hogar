# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Secreto solo servidor (Settings → API → service_role). No uses NEXT_PUBLIC_.
# El panel admin lo usa tras comprobar sesión; no lo expongas al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# URL pública del portal (enlaces copiables, metadata)
NEXT_PUBLIC_SITE_URL=https://portal.formulahogar.com
